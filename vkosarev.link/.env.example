# ─── vkosarev.link — переменные окружения ───────────────────────────────────
# Скопировать в .env и заполнить реальными значениями.
# Файл .env НЕ коммитится в репозиторий.

# ───────────────────────────────────────────────────────────────────────────
# ТЛС-сертификаты
# ───────────────────────────────────────────────────────────────────────────
# Путь к папке с TLS-сертификатами на хосте.
# Ожидаемые файлы:
#   fullchain.pem
#   vkosarev.link_privatekey.key
CERT_DIR=/root/cert

# ───────────────────────────────────────────────────────────────────────────
# 3x-ui — управление Xray VPN панелью
# ───────────────────────────────────────────────────────────────────────────
# Адрес панели 3x-ui для экспортёра метрик (внутри Docker-сети)
XUI_EXPORTER_ORIGIN=https://host.docker.internal:2055/vkosarev.name.eu/

# Учётные данные для доступа к панели 3x-ui (для 3x-ui-exporter)
XUI_EXPORTER_USERNAME=vkosarev
XUI_EXPORTER_PASSWORD=changeme

# Порт, на котором экспортёр слушает метрики для Prometheus
# (по умолчанию 3001, контейнер слушает на 3000 и проксирует на 3001)
XUI_EXPORTER_PORT=3001

# ───────────────────────────────────────────────────────────────────────────
# Данные контейнеров (по умолчанию ./path)
# ───────────────────────────────────────────────────────────────────────────
# Portainer: данные и конфигурация (по умолчанию ./portainer/data)
PORTAINER_DATA=./portainer/data

# OpenVPN: существующие данные на сервере (если используется)
# OPENVPN_DATA=/root/ovpn/openvpn-data

# Prometheus: временные ряды и конфигурация (по умолчанию ./prometheus/data)
PROMETHEUS_DATA=./prometheus/data

# ───────────────────────────────────────────────────────────────────────────
# Инфраструктура и мониторинг
# ───────────────────────────────────────────────────────────────────────────
# Имя узла (используется в Prometheus и других сервисах)
NODE_NAME=vkosarev.link
