# ─── vkosarev.link — переменные окружения ───────────────────────────────────
# Скопировать в .env и заполнить реальными значениями.
# Файл .env НЕ коммитится в репозиторий.

# Путь к папке с TLS-сертификатами на хосте
# Ожидаемые файлы:
#   fullchain.pem
#   vkosarev.link_privatekey.key
CERT_DIR=/tools/nginx/cert

# Данные Portainer (по умолчанию ./portainer/data)
# PORTAINER_DATA=./portainer/data

# Данные OpenVPN — существующие данные на сервере:
OPENVPN_DATA=/root/ovpn/openvpn-data

# Путь к конфигу frps (по умолчанию ./frps/frps1.toml)
# FRPS_CONFIG=./frps/frps1.toml

# Данные Prometheus (по умолчанию ./prometheus/data)
# PROMETHEUS_DATA=./prometheus/data
